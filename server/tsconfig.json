{
  "compilerOptions": {
    "module": "ESNext",
    "esModuleInterop": true,
    "target": "ES2022",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "allowJs": true,
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "include": ["./**/*"],
  "watchOptions": {
    "watchFile": "dynamicPriorityPolling"
  }
}